---
import { newsletter } from '~/config/site';

// Substack publication URL — built from the publication slug.
// To change which publication this points at, edit `newsletter.substackHandle`
// in src/config/site.ts.
const substackEmbedUrl = `https://${newsletter.substackHandle}.substack.com/embed`;
---

<section class="newsletter container" aria-labelledby="newsletter-title" style="margin-bottom: 2rem;">
  <div>
    <span class="eyebrow" style="color: var(--brand-yellow);">Newsletter</span>
    <h2 id="newsletter-title">{newsletter.ctaTitle}</h2>
    <p>{newsletter.ctaBlurb}</p>
  </div>

  <div class="substack-wrap">
    <iframe
      src={substackEmbedUrl}
      title="Subscribe to A Resonant Life"
      loading="lazy"
      width="480"
      height="320"
      frameborder="0"
      scrolling="no"
    ></iframe>
  </div>
</section>

<style>
  .substack-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 480px;
    background: var(--paper);
    border-radius: 16px;
    overflow: hidden;
    border: 2px solid var(--brand-yellow);
    box-shadow: 0 18px 40px -20px rgba(0, 0, 0, 0.4);
  }
  .substack-wrap iframe {
    display: block;
    width: 100%;
    border: 0;
    background: transparent;
  }
</style>
