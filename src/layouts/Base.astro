---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { site } from '~/config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pathname?: string;
}

const {
  title,
  description = site.description,
  ogImage = '/brand/cover-main.png',
  pathname = Astro.url.pathname,
} = Astro.props;

const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
const canonical = new URL(pathname, site.url).toString();
const ogImageAbs = new URL(ogImage, site.url).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/brand/cover-main.png" />
    <link rel="canonical" href={canonical} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="theme-color" content="#e64531" />
  </head>
  <body>
    <Header pathname={pathname} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
